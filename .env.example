# Maintenance mode — set to "true" to activate, then restart the Node.js process
MAINTENANCE_MODE=false
MAINTENANCE_BYPASS_SECRET=

# App
NEXT_PUBLIC_BASE_URL=

# GSAP
GSAP_AUTH_TOKEN=

# HubSpot
HUBSPOT_ACCESS_TOKEN=
NEXT_PUBLIC_HUBSPOT_PORTAL_ID=
HUBSPOT_NEWSLETTER_FORM_ID=
HUBSPOT_CONTACT_FORM_ID=

# Analytics
NEXT_PUBLIC_GOOGLE_TAG_MANAGER_ID=
NEXT_PUBLIC_GOOGLE_ANALYTICS=
NEXT_PUBLIC_FACEBOOK_APP_ID=
NEXT_PUBLIC_CLARITY_PROJECT_ID=

# Cloudflare Turnstile CAPTCHA
NEXT_PUBLIC_CLOUDFLARE_TURNSTILE_SITE_KEY=
CLOUDFLARE_TURNSTILE_SECRET_KEY=

# CMS root user (used to bootstrap the first admin account)
ROOT_USER_ID=
ROOT_USER_PASS=

# CMS session signing secret — generate with: openssl rand -hex 32
CMS_SESSION_SECRET=

# Vercel Secrets
BLOB_READ_WRITE_TOKEN=
VERCEL_OIDC_TOKEN=

# Vercel Postgres — auto-injected per environment when linked in the Vercel dashboard.
# One Neon DB with two branches: main (Production) and staging (Preview + Development).
# For local dev: vercel env pull .env.vercel.local, then copy values here.
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=
